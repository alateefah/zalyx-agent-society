# Qwen Cloud Configuration
QWEN_API_KEY=your_qwen_cloud_api_key_here
QWEN_API_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-max
# Alternative: QWEN_MODEL=qwen-plus (faster, cheaper)

# Logging
LOG_LEVEL=info

# Merchant Data Path (optional - for real data experiments)
MERCHANT_DATA_PATH=./data/sample-merchants/

# Agent Configuration
AGENT_TIMEOUT_MS=30000
MAX_RETRIES=2
