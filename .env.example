# Qwen Cloud API Key — get yours at https://dashscope-intl.aliyuncs.com
QWEN_API_KEY=your_qwen_cloud_api_key_here

# Model selection (qwen-max recommended for best reasoning)
QWEN_MODEL=qwen-max

# DashScope API base URL (Alibaba Cloud)
QWEN_API_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Server port
PORT=3001
