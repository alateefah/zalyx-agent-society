# Qwen Cloud API Key — required. Get yours at https://dashscope-intl.aliyuncs.com
QWEN_API_KEY=your_qwen_cloud_api_key_here

# Model selection (qwen-max recommended for best reasoning)
QWEN_MODEL=qwen-max
QWEN_TEMPERATURE=0

# DashScope API base URL (Alibaba Cloud)
QWEN_API_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Server port
PORT=3001

# Data backend:
# - local: read/write merchants from LOCAL_MERCHANTS_DIR and decisions locally
# - tablestore: use Alibaba Cloud Tablestore
# Default is local in development and tablestore in NODE_ENV=production.
DATA_BACKEND=local

# ── Alibaba Cloud Tablestore (OTS) ────────────────────────────────────────────
# Set all four values to use the Alibaba Cloud merchant table.
# If omitted locally, merchants are read/written from LOCAL_MERCHANTS_DIR.
OTS_ENDPOINT=https://<instance>.<region>.ots.aliyuncs.com
OTS_INSTANCE=<your_instance_name>
OTS_ACCESS_KEY_ID=
OTS_ACCESS_KEY_SECRET=

# Table names (auto-created on first run when credentials are present)
OTS_MERCHANTS_TABLE=zalyx_merchants
OTS_DECISIONS_TABLE=zalyx_decisions

# Decision storage: auto = Tablestore when OTS is configured, local JSON otherwise.
# Set to local to force local decision history during development.
DECISION_STORE=auto
LOCAL_MERCHANTS_DIR=data/snapshots
LOCAL_DECISIONS_FILE=data/decisions.local.json

# Deployment refresh:
# Set both values on Alibaba ECS when you intentionally want a fresh demo reset.
# This deletes/recreates the configured OTS tables, then preloads the default
# merchant snapshots from data/snapshots before the server starts.
RESET_TABLESTORE_ON_DEPLOY=false
CONFIRM_TABLESTORE_RESET=
