# Qwen Cloud API Key — get yours at https://dashscope-intl.aliyuncs.com
QWEN_API_KEY=your_qwen_cloud_api_key_here

# Model selection (qwen-max recommended for best reasoning)
QWEN_MODEL=qwen-max

# DashScope API base URL (Alibaba Cloud)
QWEN_API_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Server port
PORT=3001

# ── Alibaba Cloud Tablestore (OTS) ────────────────────────────────────────────
# Leave blank to run in MOCK mode (merchants from data/snapshots, decisions in
# data/decisions.local.json). Set all four to use a real Tablestore instance.
OTS_ENDPOINT=https://<instance>.<region>.ots.aliyuncs.com
OTS_INSTANCE=<your_instance_name>
OTS_ACCESS_KEY_ID=
OTS_ACCESS_KEY_SECRET=

# Table names (auto-created on first run when credentials are present)
OTS_MERCHANTS_TABLE=zalyx_merchants
OTS_DECISIONS_TABLE=zalyx_decisions
